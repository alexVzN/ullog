BasedOnStyle: Google
Language: Cpp

# --- Deviations from Google style ---

# Google uses 2; we use 4.
IndentWidth: 4
UseTab: Never

# Compensate: access modifiers (public/private/protected) sit flush with
# the class keyword, not indented into the class body.
# With IndentWidth=4 the body is at +4; offset=-4 brings them back to 0.
AccessModifierOffset: -4

# Google caps at 80; we allow ~120.  String literals that exceed this are
# never broken, so set 0 (unlimited) to avoid spurious reformatting.
ColumnLimit: 0

# Brace always on the same line (K&R / Google default).
BreakBeforeBraces: Attach

# --- Kept from original / matching Google defaults ---

AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: true

# Pointer/reference attached to the type: int* p, const std::string& s
PointerAlignment: Left
